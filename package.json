{
  "name": "teamplates-psico",
  "version": "1.0.0",
  "description": "Sistema de templates profesionales de portfolios para psicólogas",
  "main": "backend/server.js",
  "scripts": {
    "dev": "concurrently \"npm run dev:frontend\" \"npm run dev:backend\"",
    "dev:frontend": "cd src && vite",
    "dev:backend": "nodemon backend/server.js",
    "build": "echo 'Build complete - using static files'",
    "build:frontend": "cd src && vite build",
    "build:backend": "echo 'Backend build complete'",
    "test": "jest",
    "start": "node backend/server.js",
    "lint": "eslint . --ext .js,.jsx,.ts,.tsx",
    "format": "prettier --write \"**/*.{js,jsx,ts,tsx,css,md}\"",
    "db:migrate": "node backend/database/migrate.js",
    "db:seed": "node backend/database/seed.js"
  },
  "keywords": [
    "portfolio",
    "template",
    "psicologia",
    "profesional"
  ],
  "author": "Tu Nombre",
  "license": "PROPRIETARY",
  "devDependencies": {
    "@babel/core": "^7.23.0",
    "@babel/preset-env": "^7.23.0",
    "@babel/preset-react": "^7.23.0",
    "concurrently": "^8.2.0",
    "eslint": "^8.50.0",
    "nodemon": "^3.0.0",
    "prettier": "^3.0.0",
    "vite": "^5.0.0"
  },
  "dependencies": {
    "axios": "^1.6.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "jsonwebtoken": "^9.0.0",
    "pg": "^8.11.0",
    "validator": "^13.11.0"
  }
}
