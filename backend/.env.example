# ============================================
# CONFIGURACIÓN DE EMAILS
# ============================================

# Opción 1: Gmail
# SMTP_SERVICE=gmail
# SMTP_USER=tu-email@gmail.com
# SMTP_PASS=tu-contraseña-de-aplicación

# Opción 2: SMTP personalizado
SMTP_HOST=smtp.tu-servidor.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=tu-email@tu-dominio.com
SMTP_PASS=tu-contraseña

# Email del administrador (donde llegan las notificaciones)
ADMIN_EMAIL=licgonzalezcandela@gmail.com

# Configuración del servidor
PORT=3000
NODE_ENV=production

# CORS
CORS_ORIGIN=https://licgonzalezcandela.github.io
